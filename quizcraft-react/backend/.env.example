# ---------------------------
# Server Configuration
# ---------------------------
PORT=3001
APP_URL=http://localhost:5173

# ---------------------------
# JWT Authentication
# ---------------------------
JWT_SECRET=your_long_random_jwt_secret
JWT_EXPIRES_IN=7d

# ---------------------------
# Database (PostgreSQL / Supabase)
# ---------------------------
# Preferred: pooled transaction URL from Supabase (port 6543)
DATABASE_URL=postgresql://postgres:<password>@<project-ref>.supabase.co:6543/postgres
# Optional alias supported by backend
SUPABASE_DB_URL=
# Set to false only for local non-SSL Postgres
DB_SSL=true

# ---------------------------
# Google Gemini AI
# ---------------------------
GEMINI_API_KEY=your_gemini_api_key_here

# ---------------------------
# Email (SMTP)
# ---------------------------
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USER=your_email@example.com
MAIL_PASS=your_email_password
MAIL_FROM="QuizCraft AI <noreply@example.com>"

# ---------------------------
# Optional Settings
# ---------------------------
# Keep this false unless you are using RPC read mode in parallel.
USE_SUPABASE=false
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

MAX_FILE_SIZE=5242880    # 5MB file upload limit